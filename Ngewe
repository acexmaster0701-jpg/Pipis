        local function getUserId() return tostring(Player.UserId) end

        local function getAvatarThumbnail(userId)
            return "rbxthumb://type=AvatarHeadShot&id=" .. tostring(userId) .. "&w=150&h=150"
        end

        function Chat_API.AddUser(userId, username)
            local url = string.format("%s?format=json&event=add_user&userid=%s&username=%s",
                Chat_API.URL,
                HttpService2:UrlEncode(userId),
                HttpService2:UrlEncode(username)
            )
            pcall(function() httpRequest({ Url = url, Method = "GET" }) end)
        end

        function Chat_API.Heartbeat(userId)
            local url = string.format("%s?format=json&event=heartbeat&userid=%s",
                Chat_API.URL,
                HttpService2:UrlEncode(userId)
            )
            pcall(function() httpRequest({ Url = url, Method = "GET" }) end)
        end

        function Chat_API.SendMessage(userId, message, timestamp)
            timestamp = timestamp or math.floor(os.time())
            local url = string.format("%s?format=json&event=chat&message=%s&userid=%s&timestamp=%d",
                Chat_API.URL,
                HttpService2:UrlEncode(message),
                HttpService2:UrlEncode(userId),
                timestamp
            )
            pcall(function() httpRequest({ Url = url, Method = "GET" }) end)
        end

        function Chat_API.GetMessages()
            local success, result = pcall(function()
                return httpRequest({ Url = Chat_API.URL .. "?format=json", Method = "GET" })
            end)
            if success and result and result.Body then
                return HttpService2:JSONDecode(result.Body)
            end
            return { messages = {}, users = { value = 0, stored = {} } }
        end

