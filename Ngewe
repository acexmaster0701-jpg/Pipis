local function ProtectedBlackout()
    local TweenService = game:GetService("TweenService")

    local existingGui = Player.PlayerGui:FindFirstChild("PhantomBlackout")
    if existingGui then
        existingGui:Destroy()
    end

    local blackoutGui = Instance.new("ScreenGui")
    blackoutGui.Name = "PhantomBlackout"
    blackoutGui.ResetOnSpawn = false
    blackoutGui.IgnoreGuiInset = true
    blackoutGui.DisplayOrder = 99999
    blackoutGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    blackoutGui.Parent = Player:WaitForChild("PlayerGui")

    local blackoutFrame = Instance.new("Frame")
    blackoutFrame.Size = UDim2.new(1, 0, 1, 0)
    blackoutFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    blackoutFrame.BackgroundTransparency = 1
    blackoutFrame.BorderSizePixel = 0
    blackoutFrame.ZIndex = 9999
    blackoutFrame.Visible = false
    blackoutFrame.Parent = blackoutGui

    local blackoutLabel = Instance.new("TextLabel")
    blackoutLabel.Size = UDim2.new(1, 0, 0, 60)
    blackoutLabel.Position = UDim2.new(0, 0, 0.5, -30)
    blackoutLabel.BackgroundTransparency = 1
    blackoutLabel.Text = "phantom.wtf"
    blackoutLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    blackoutLabel.TextSize = 32
    blackoutLabel.Font = Enum.Font.GothamBold
    blackoutLabel.ZIndex = 10000
    blackoutLabel.Parent = blackoutFrame

    local dotsThread = nil
    local dotLabel = Instance.new("TextLabel")
    dotLabel.Size = UDim2.new(1, 0, 0, 30)
    dotLabel.Position = UDim2.new(0, 0, 0.5, 30)
    dotLabel.BackgroundTransparency = 1
    dotLabel.Text = ""
    dotLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    dotLabel.TextSize = 20
    dotLabel.Font = Enum.Font.Gotham
    dotLabel.ZIndex = 10000
    dotLabel.Parent = blackoutFrame

    local function HideAllGUI()
        for _, gui in pairs(Player.PlayerGui:GetChildren()) do
            if gui.Name ~= "PhantomBlackout" then
                pcall(function()
                    gui.Enabled = false
                end)
            end
        end
    end

    local function ShowAllGUI()
        for _, gui in pairs(Player.PlayerGui:GetChildren()) do
            if gui.Name ~= "PhantomBlackout" then
                pcall(function()
                    gui.Enabled = true
                end)
            end
        end
    end

    local function showBlackout()
        HideAllGUI()

        blackoutFrame.BackgroundTransparency = 1
        blackoutFrame.Visible = true

        local tween = TweenService:Create(blackoutFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad),
            { BackgroundTransparency = 0 })
        tween:Play()
        tween.Completed:Wait()

        local dots = 0
        dotsThread = task.spawn(function()
            while blackoutFrame and blackoutFrame.Visible do
                dots = (dots % 3) + 1
                dotLabel.Text = string.rep(".", dots)
                task.wait(0.4)
            end
        end)
    end

    local function hideBlackout()
        if dotsThread then
            task.cancel(dotsThread)
            dotsThread = nil
        end
        dotLabel.Text = ""

        if blackoutFrame then
            local tween = TweenService:Create(blackoutFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad),
                { BackgroundTransparency = 1 })
            tween:Play()
            tween.Completed:Wait()
            blackoutFrame.Visible = false
        end

        ShowAllGUI()
    end

    return showBlackout, hideBlackout, blackoutGui
end

local showBlackout, hideBlackout, blackoutGui = ProtectedBlackout()

