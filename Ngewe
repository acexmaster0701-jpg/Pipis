    local function afDoSell()
        local sellP = nil
        local ch = Player.Character
        local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local pos
                local part = obj.Parent
                if part:IsA("Attachment") then
                    pos = part.WorldPosition
                elseif part:IsA("BasePart") then
                    pos = part.Position
                elseif part:IsA("Model") then
                    local rp = part.PrimaryPart or part:FindFirstChildOfClass("BasePart")
                    if rp then pos = rp.Position end
                end
                if pos and (pos - hrp.Position).Magnitude < 10 then
                    sellP = obj
                    break
                end
            end
        end

        if not sellP then return end

        pcall(function()
            sellP.MaxActivationDistance = 9999
            sellP.RequiresLineOfSight = false
        end)

        local function getMarsh()
            local list = {}
            if Player.Backpack then
                for _, v in pairs(Player.Backpack:GetChildren()) do
                    if v:IsA("Tool") and v.Name:lower():find("marshmallow") then
                        table.insert(list, v)
                    end
                end
            end
            if Player.Character then
                for _, v in pairs(Player.Character:GetChildren()) do
                    if v:IsA("Tool") and v.Name:lower():find("marshmallow") then
                        table.insert(list, v)
                    end
                end
            end
            return list
        end

        local list = getMarsh()
        for idx, marsh in ipairs(list) do
            if not AF.active then break end
            while AF.paused and AF.active do task.wait(0.3) end
            local hum = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid")
            if not hum then break end
            pcall(function() hum:EquipTool(marsh) end)
            task.wait(0.08)
            pcall(function() fireproximityprompt(sellP) end)
            task.wait(0.18)
            afSetStatus(("Sell Marshmallow %d/%d"):format(idx, #list), Color3.fromRGB(0, 220, 120))
        end

        pcall(function()
            if sellP and sellP.Parent then
                sellP.MaxActivationDistance = 10
                sellP.RequiresLineOfSight = true
            end
        end)
    end

    local function afDoBuyPack(qty)
        local RS2 = game:GetService("ReplicatedStorage")
        local remEvts = RS2:FindFirstChild("RemoteEvents")
        local spRE = remEvts and remEvts:FindFirstChild("StorePurchase")
        if not spRE then
            afSetStatus("RemoteEvent tidak ada!", Color3.fromRGB(255, 80, 80))
            return
        end

        local function countItem(name)
            local n = 0
            for _, t in ipairs(Player.Backpack:GetChildren()) do
                if t.Name == name then n = n + 1 end
            end
            local ch = Player.Character
            if ch then
                for _, t in ipairs(ch:GetChildren()) do
                    if t:IsA("Tool") and t.Name == name then n = n + 1 end
                end
            end
            return n
        end

        local packItems = { "Water", "Sugar Block Bag", "Gelatin" }
        for _, item in ipairs(packItems) do
            if not AF.active then break end

            local before = countItem(item)
            local needed = qty
            afSetStatus(("Beli %s x%d..."):format(item, needed), Color3.fromRGB(100, 180, 255))

            for i = 1, needed do
                if not AF.active then break end
                while AF.paused and AF.active do task.wait(0.2) end
                pcall(function() spRE:FireServer(item, 0.1) end)
                task.wait(0.4)
            end

            local elapsed = 0
            local gained = 0
            repeat
                if not AF.active then break end
                task.wait(0.2)
                elapsed = elapsed + 0.2
                gained = countItem(item) - before
            until gained >= needed or elapsed > 8

            local missing = needed - gained
            if missing > 0 and AF.active then
                afSetStatus(("Retry %s x%d..."):format(item, missing), Color3.fromRGB(255, 160, 40))
                for i = 1, missing do
                    if not AF.active then break end
                    pcall(function() spRE:FireServer(item, 1) end)
                    task.wait(0.5)
                end
                elapsed = 0
                repeat
                    if not AF.active then break end
                    task.wait(0.2)
                    elapsed = elapsed + 0.2
                    gained = countItem(item) - before
                until gained >= needed or elapsed > 5
            end

            afSetStatus(("%s x%d masuk"):format(item, math.min(gained, needed)), Color3.fromRGB(0, 220, 100))
            task.wait(0.3)
        end
        task.wait(1)
    end

    local function doOneCook()
        task.wait(0.2)

        local snapS = S.patStats.small
        local snapM = S.patStats.medium
        local snapL = S.patStats.large

        local function countItem(name)
            local n = 0
            for _, t in ipairs(Player.Backpack:GetChildren()) do
                if t.Name == name then n = n + 1 end
            end
            local ch = Player.Character
            if ch then
                for _, t in ipairs(ch:GetChildren()) do
                    if t:IsA("Tool") and t.Name == name then n = n + 1 end
                end
            end
            return n
        end

        local function equipTool(name)
            local hum = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid")
            if not hum then return false end
            local tool = Player.Backpack:FindFirstChild(name)
            if tool then
                hum:EquipTool(tool)
                task.wait(0.2)
                return true
            end
            return false
        end

        local function firePromptNearby(radius)
            local ch = Player.Character
            local root = ch and ch:FindFirstChild("HumanoidRootPart")
            if not root then return end
            local parts = workspace:GetPartBoundsInRadius(root.Position, radius or 8)
            for _, part in ipairs(parts) do
                if part:IsA("BasePart") then
                    for _, obj in ipairs(part:GetDescendants()) do
                        if obj:IsA("ProximityPrompt") then
                            pcall(function()
                                obj.RequiresLineOfSight = false
                                fireproximityprompt(obj)
                            end)
                        end
                    end
                end
            end
        end

        local function cookInteract(toolName)
            if toolName then
                equipTool(toolName)
                task.wait(0.2)
            end
            firePromptNearby(8)
            task.wait(0.1)
            pcall(function()
                VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                task.wait(0.15)
                VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
            end)
            task.wait(0.1)
            firePromptNearby(8)
        end

        local function popTimer()
            for i = 1, #S.rpcQueue do
                local v = S.rpcQueue[i]
                if v.type == "timer" then
                    table.remove(S.rpcQueue, i)
                    return v.secs
                end
            end
            return nil
        end

        local function waitRPC(instrType, timeout)
            local start = tick()
            while tick() - start < timeout do
                for i = 1, #S.rpcQueue do
                    local inst = S.rpcQueue[i]
                    if inst and inst.type == instrType then
                        table.remove(S.rpcQueue, i)
                        return inst
                    end
                end
                task.wait(0.1)
            end
            return nil
        end

        local function countdown(secs, phaseTxt)
            for i = secs, 1, -1 do
                if not AF.active then return false end
                afSetStatus(phaseTxt .. " " .. i .. "s", Color3.fromRGB(255, 160, 60))
                task.wait(1)
            end
            return true
        end

        local CFG = S.CFG or { WATER_WAIT = 20, COOK_WAIT = 46 }

        afSetStatus("Adding Water...", Color3.fromRGB(100, 180, 255))
        cookInteract("Water")

        local boilSecs
        for _ = 1, 30 do
            boilSecs = popTimer()
            if boilSecs then break end
            task.wait(0.1)
        end
        boilSecs = boilSecs or CFG.WATER_WAIT

        if not countdown(boilSecs, "Boiling...") then return false end

        waitRPC("add_sugar", 0.5)
        if not AF.active then return false end

        afSetStatus("Adding Sugar...", Color3.fromRGB(100, 180, 255))
        cookInteract("Sugar Block Bag")
        task.wait(0.2)

        waitRPC("add_gelatin", 0.5)
        if not AF.active then return false end

        afSetStatus("Adding Gelatin...", Color3.fromRGB(100, 180, 255))
        cookInteract("Gelatin")
        task.wait(0.2)

        local cookSecs
        for _ = 1, 30 do
            cookSecs = popTimer()
            if cookSecs then break end
            task.wait(0.1)
        end
        cookSecs = cookSecs or CFG.COOK_WAIT

        if not countdown(cookSecs, "Cooking...") then return false end

        waitRPC("bag_result", 0.5)
        if not AF.active then return false end

        local bag
        local t2 = 0
        repeat
            bag = Player.Backpack:FindFirstChild("Empty Bag")
            task.wait(0.3)
            t2 = t2 + 0.3
        until bag or t2 > 10

        if not bag then
            afSetStatus("No Empty Bag!", Color3.fromRGB(255, 80, 80))
            return false
        end

        afSetStatus("Taking MS...", Color3.fromRGB(100, 180, 255))
        cookInteract("Empty Bag")

        local waitMS = 0
        local newS, newM, newL
        repeat
            task.wait(0.3)
            waitMS = waitMS + 0.3
            newS = countItem("Small Marshmallow Bag") - snapS
            newM = countItem("Medium Marshmallow Bag") - snapM
            newL = countItem("Large Marshmallow Bag") - snapL
        until (newS > 0 or newM > 0 or newL > 0) or waitMS > 8

        if newS > 0 then
            S.patStats.small = S.patStats.small + newS
        elseif newM > 0 then
            S.patStats.medium = S.patStats.medium + newM
        elseif newL > 0 then
            S.patStats.large = S.patStats.large + newL
        else
            S.patStats.small = S.patStats.small + 1
        end

        return true
    end

    local tpToPos = function(cx, cy, cz, destName)
        local x, y, z
        if type(cx) == "CFrame" then
            local pos = cx.Position
            x, y, z = pos.X, pos.Y, pos.Z
            if type(cy) == "string" then destName = cy end
        elseif typeof(cx) == "Vector3" then
            x, y, z = cx.X, cx.Y, cx.Z
            if type(cy) == "string" then destName = cy end
        elseif type(cx) == "table" then
            x = cx.x or cx.X or 0
            y = cx.y or cx.Y or 0
            z = cx.z or cx.Z or 0
            if type(cy) == "string" then destName = cy end
        else
            x, y, z = cx, cy, cz
        end

        if tpActive then return end
        tpActive = true
        tpCancelled = false

        local safePos = GetSafeGroundPosition(Vector3.new(x, y, z))
        x, y, z = safePos.X, safePos.Y, safePos.Z

        local ch = Player.Character
        local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
        local hum = ch and ch:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then
            tpActive = false
            return
        end

        showBlackout()

        if game.PlaceId == 15124180230 or S.teleportMode == "CONSOLE" then
            hrp.CFrame = CFrame.new(x, y + 3, z)
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            if hum then
                hum.Sit = false
                task.wait(0.05)
                pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
                task.wait(0.1)
                pcall(function() hum:ChangeState(Enum.HumanoidStateType.Running) end)
            end
            hideBlackout()
            tpActive = false
            return
        end

        local function moveCharTo(targetPos)
            local ch2 = Player.Character
            local hrp2 = ch2 and ch2:FindFirstChild("HumanoidRootPart")
            if not hrp2 then return end
            local offset = targetPos - hrp2.Position
            for _, p in pairs(ch2:GetDescendants()) do
                if p:IsA("BasePart") and p ~= hrp2 then
                    pcall(function() p.CFrame = p.CFrame + offset end)
                end
            end
            hrp2.CFrame = CFrame.new(targetPos) * (hrp2.CFrame - hrp2.CFrame.Position)
            hrp2.AssemblyLinearVelocity = Vector3.zero
            hrp2.AssemblyAngularVelocity = Vector3.zero
        end

        local function lerpChar(fromPos, toPos, speed)
            local dist = (toPos - fromPos).Magnitude
            if dist < 0.05 then return true end
            local travelT = dist / speed
            local elapsed = 0
            while elapsed < travelT and not tpCancelled do
                local hrp2 = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                if not hrp2 then return false end
                local t = math.clamp(elapsed / travelT, 0, 1)
                local nextPos = fromPos:Lerp(toPos, t)
                moveCharTo(nextPos)
                local _, dt = RunService.Stepped:Wait()
                elapsed = elapsed + dt
            end
            if not tpCancelled then moveCharTo(toPos) end
            return not tpCancelled
        end

        local startPos = hrp.Position
        local UNDERGROUND_Y = -4.50
        local TP_SPEED = 22.5

        local deathConn
        deathConn = Player.CharacterAdded:Connect(function()
            tpCancelled = true
        end)

        local underPos = Vector3.new(hrp.Position.X, UNDERGROUND_Y, hrp.Position.Z)
        local ok = lerpChar(hrp.Position, underPos, TP_SPEED)

        if ok and not tpCancelled then
            local hrp2 = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            if hrp2 then
                local slideTarget = Vector3.new(x, UNDERGROUND_Y, z)
                ok = lerpChar(hrp2.Position, slideTarget, TP_SPEED)
            else
                ok = false
            end
        end

        if ok and not tpCancelled then
            local hrp3 = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            if hrp3 then
                local riseTarget = Vector3.new(x, y + 3, z)
                ok = lerpChar(hrp3.Position, riseTarget, TP_SPEED)
            end
        end

        if deathConn then deathConn:Disconnect() end

        local ch2 = Player.Character
        local hum2 = ch2 and ch2:FindFirstChildOfClass("Humanoid")
        if hum2 then
            hum2.Sit = false
            task.wait(0.05)
            pcall(function() hum2:ChangeState(Enum.HumanoidStateType.GettingUp) end)
            task.wait(0.1)
            pcall(function() hum2:ChangeState(Enum.HumanoidStateType.Running) end)
        end

        hideBlackout()
        tpActive = false
    end

    local doSuicideTP = function(loc)
        tpBusy = true
        local RESPAWN_WARP = Vector3.new(999999, 9999999, 999999)

        showBlackout()

        local ch = Player.Character
        local hrp0 = ch and ch:FindFirstChild("HumanoidRootPart")
        if not hrp0 then
            hideBlackout()
            tpBusy = false
            return
        end

        if game.PlaceId == 15124180230 or S.teleportMode == "CONSOLE" then
            hrp0.CFrame = CFrame.new(loc.x, loc.y + 3, loc.z)
            hrp0.AssemblyLinearVelocity = Vector3.zero
            hrp0.AssemblyAngularVelocity = Vector3.zero
            hideBlackout()
            tpBusy = false
            return
        end

        hrp0.CFrame = CFrame.new(RESPAWN_WARP)

        local newChar = Player.CharacterAdded:Wait()
        local hrp = newChar:WaitForChild("HumanoidRootPart", 10)
        local hum = newChar:WaitForChild("Humanoid", 10)
        if not hrp or not hum then
            hideBlackout()
            tpBusy = false
            return
        end

        local waited = 0
        while hum.Health <= 0 and waited < 5 do
            task.wait(0.1)
            waited = waited + 0.1
        end
        task.wait(0.8)

        local safePos = GetSafeGroundPosition(Vector3.new(loc.x, loc.y, loc.z))
        local targetCF = CFrame.new(safePos)
        for _ = 1, 4 do
            hrp.CFrame = targetCF
            task.wait(0.15)
        end

        hideBlackout()
        tpBusy = false
    end

