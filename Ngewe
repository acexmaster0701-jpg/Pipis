    local TweenService = cloneref(game:GetService("TweenService"))
    local function snapToCookPos()
        local targetPos = S.cookPos
        if not targetPos then
            warn("snapToCookPos: S.cookPos is nil")
            return
        end
        local ch = Player.Character
        if not ch then
            warn("snapToCookPos: no character")
            return
        end
        local hrp = ch:FindFirstChild("HumanoidRootPart")
        if not hrp then
            warn("snapToCookPos: no HumanoidRootPart")
            return
        end

        local targetCF = CFrame.new(targetPos)
        local dist = (hrp.Position - targetCF.Position).Magnitude
        if dist < 0.5 then return end

        local success, err = pcall(function()
            local tw = TweenService:Create(hrp,
                TweenInfo.new(math.max(dist / 10000, 0.05), Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
                { CFrame = targetCF }
            )
            tw:Play()
            tw.Completed:Wait()
        end)
        if not success then
            warn("snapToCookPos tween error: " .. tostring(err))
        end
    end

