                HttpService3.RequestAsync,
            }

            local globals = { "request", "http_request" }
            for _, name in ipairs(globals) do
                local fn = _G[name]
                if type(fn) == "function" then
                    table.insert(protected, fn)
                end
            end
            if http and http.request then table.insert(protected, http.request) end
            if syn and syn.request then table.insert(protected, syn.request) end

            local originals = {}
            for _, fn in ipairs(protected) do
                originals[fn] = fn
