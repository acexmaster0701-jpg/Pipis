    -- Poll for new messages every 3 seconds (less aggressive to avoid rate limit)
    local sentCache = {}
    local activeUsersCount = 0

    task.spawn(function()
        while true do
            local data = Chat.GetMessages()
            if data and data.messages then
                activeUsersCount = data.users and data.users.value or 0
                pcall(function()
                    GlobalChat:SetStatusText(tostring(activeUsersCount) .. " active")
                end)

                -- Process new messages
                for _, msg in ipairs(data.messages) do
                    local key = msg.userid .. "_" .. msg.timestamp .. "_" .. msg.message
                    if not sentCache[key] then
                        sentCache[key] = true

                        -- Get sender name (fallback to "Unknown")
                        local senderName = "Unknown"
                        if data.users and data.users.stored and data.users.stored[msg.userid] then
                            local usernames = data.users.stored[msg.userid].usernames
                            if usernames and #usernames > 0 then
                                senderName = usernames[1]
                            end
                        end

                        local timeStr = os.date("%H:%M", msg.timestamp)
                        local displayName = senderName .. " · " .. timeStr
                        local senderAvatar = "rbxthumb://type=AvatarHeadShot&id=" .. msg.userid .. "&w=150&h=150"
                        local isSelf = (msg.userid == myUserId)

                        GlobalChat:SendMessage(senderAvatar, displayName, msg.message, isSelf)
                    end
                end

                -- Trim cache if too large (prevent memory leak)
                if #sentCache > 1000 then
                    local keys = {}
                    for k in pairs(sentCache) do
                        table.insert(keys, k)
                    end
                    for i = 1, #keys - 500 do
                        sentCache[keys[i]] = nil
                    end
