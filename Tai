-- Get target within FOV (with whitelist)
local function GetSilentTarget(fovPos)
    local best, bestD = nil, math.huge
    local vp = Camera.ViewportSize
    local origin = (S.FOVMode == "PC") and fovPos or Vector2.new(vp.X / 2, vp.Y / 2)
    for _, p in pairs(Players:GetPlayers()) do
        if p == Player then continue end
        if not saIsAllowed(p) then continue end
        local ch  = p.Character
        local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
        local hum = ch and ch:FindFirstChildOfClass("Humanoid")
        local hit = ch and ch:FindFirstChild(S.SilentAimPart)
        if not hrp or not hum or not hit or hum.Health <= 0 then continue end
        local sp, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if not onScreen then continue end
        local d = (origin - Vector2.new(sp.X, sp.Y)).Magnitude
        if d < S.FovSize and d < bestD then
            best = p
            bestD = d
        end
    end
    return best
end

-- Hooking CastBlacklist (only once)
local _saHookDone = false
local function initSilentAimHook()
    if _saHookDone then return end
    _saHookDone = true
    task.spawn(function()
        task.wait(0.5)
        local ok, Gc = pcall(getgc)
        if not ok or not Gc then return end
        local CastBlacklist, CastWhitelist
        for _, v in pairs(Gc) do
            if type(v) == "function" then
                local s, info = pcall(debug.getinfo, v)
                if s and info then
                    if info.name == "CastBlacklist" then CastBlacklist = v end
                    if info.name == "CastWhitelist" then CastWhitelist = v end
                    if CastBlacklist and CastWhitelist then break end
                end
            end
        end
        Gc = nil
        if not CastBlacklist or not CastWhitelist then return end
        local OldCastBlacklist
        OldCastBlacklist = hookfunction(CastBlacklist, function(...)
            -- Use S.SilentAim here
            if not S.SilentAim then
                return OldCastBlacklist(...)
            end
            -- Hit chance
            if math.random(1, 100) > HitChance then
                return OldCastBlacklist(...)
            end
            local args = {...}
            local fovPos = UserInputService:GetMouseLocation()
            local Target = GetSilentTarget(fovPos)
            if Target then
                local hit = Target.Character and Target.Character:FindFirstChild(S.SilentAimPart)
                if hit then
                    args[2] = hit.Position - args[1]
                    if S.SilentAimWallbang then
                        args[3] = {Target.Character}
                        return CastWhitelist(table.unpack(args))
                    end
                end
            end
            return OldCastBlacklist(table.unpack(args))
        end)
    end)
end

-- Update FOV & snapline
RunService.RenderStepped:Connect(function()
    pcall(function()
        local circle = S.FovCircle
        if not circle then return end

        local cam = workspace.CurrentCamera
        if not cam then return end

        -- FOV visible now purely controlled by ShowFOV (independent)
        local showFov = S.ShowFOV
        local showLine = S.ShowSnapline

        local saOrigin
        if S.FOVMode == "PC" then
            saOrigin = UserInputService:GetMouseLocation()
        else
            local vp = cam.ViewportSize
            saOrigin = Vector2.new(vp.X / 2, vp.Y / 2)
        end

        circle.Position = saOrigin
        circle.Radius = S.FovSize
        circle.Visible = showFov

        if S.SilentLine then
            S.SilentLine.Color = S.FovCircleColor
        end

        -- Snapline
        if showLine then
            local bestTargetPart = nil
            local bestDist = math.huge
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= Player and saIsAllowed(plr) then
                    local ch = plr.Character
                    if ch then
                        local targetPart = ch:FindFirstChild(S.SilentAimPart)
                        local hum = ch:FindFirstChild("Humanoid")
                        if targetPart and hum and hum.Health > 0 then
                            local sp, onScreen = cam:WorldToViewportPoint(targetPart.Position)
                            if onScreen then
                                local d = (saOrigin - Vector2.new(sp.X, sp.Y)).Magnitude
                                if d < S.FovSize and d < bestDist then
                                    bestDist = d
                                    bestTargetPart = targetPart
                                end
                            end
                        end
                    end
                end
            end
            if bestTargetPart and S.SilentLine then
                local sp = cam:WorldToViewportPoint(bestTargetPart.Position)
                S.SilentLine.From = saOrigin
                S.SilentLine.To = Vector2.new(sp.X, sp.Y)
                S.SilentLine.Visible = true
            elseif S.SilentLine then
                S.SilentLine.Visible = false
            end
        else
            if S.SilentLine then S.SilentLine.Visible = false end
        end
    end)

    -- Aimlock (unchanged, uses S.Aimlock, S.whitelist)
    if S.Aimlock then
        local cam = workspace.CurrentCamera
        local myRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if myRoot then
            local targetPart = nil
            local bestDist = math.huge
            local fovCenter
            if S.FOVMode == "PC" then
                fovCenter = UserInputService:GetMouseLocation()
            else
                local vp = cam.ViewportSize
                fovCenter = Vector2.new(vp.X / 2, vp.Y / 2)
            end

            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= Player and not S.whitelist[plr.Name] then
                    local char = plr.Character
                    if char then
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        local target = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                        if hum and hum.Health > 0 and target then
                            local sp, onScreen = cam:WorldToViewportPoint(target.Position)
                            if onScreen then
                                local dist2D = (fovCenter - Vector2.new(sp.X, sp.Y)).Magnitude
                                if dist2D < S.FovSize and dist2D < bestDist then
                                    if S.AimlockWallCheck then
                                        local camPos = cam.CFrame.Position
                                        local dir = target.Position - camPos
                                        local params = RaycastParams.new()
                                        params.FilterType = Enum.RaycastFilterType.Blacklist
                                        params.FilterDescendantsInstances = { cam, Player.Character }
                                        local hit = workspace:Raycast(camPos, dir.Unit * dir.Magnitude, params)
                                        if hit and not hit.Instance:IsDescendantOf(char) then
                                            continue
                                        end
                                    end
                                    bestDist = dist2D
                                    targetPart = target
                                end
                            end
                        end
                    end
                end
            end

            if targetPart then
                local targetCF = CFrame.lookAt(cam.CFrame.Position, targetPart.Position)
                cam.CFrame = cam.CFrame:Lerp(targetCF, S.AimlockSmooth)
            end
        end
    end
end)

