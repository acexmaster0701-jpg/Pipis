    -- Helper: universal request function
    local function httpRequest(options)
        local success, result
        if syn and syn.request then
            success, result = pcall(syn.request, options)
        elseif http and http.request then
            success, result = pcall(http.request, options)
        elseif request then
            success, result = pcall(request, options)
        else
            error("No request function available")
        end
        return success, result
    end

    -- Safe request with automatic retry on failure (up to 3 times)
    local function safeRequest(options, retries)
        retries = retries or 3
        for i = 1, retries do
            local ok, res = httpRequest(options)
            if ok and res and res.StatusCode and res.StatusCode < 400 then
                return true, res
            end
            if ok and res and res.StatusCode == 429 then
                -- Rate limited: wait 3 seconds and retry
                task.wait(3)
            else
                task.wait(0.5 * i)
            end
        end
        return false, nil
    end

    -- Encode URL components safely
    local function urlEncode(str)
        return HttpService:UrlEncode(tostring(str))
    end

    -- Build query string
    local function buildQuery(params)
        local parts = {}
        for k, v in pairs(params) do
            table.insert(parts, urlEncode(k) .. "=" .. urlEncode(v))
        end
        return table.concat(parts, "&")
    end

    -- Core API functions
    function Chat.AddUser(userId, username)
        local query = buildQuery({
            format = "json",
            event = "add_user",
            userid = userId,
            username = username,
        })
        local url = Chat.URL .. "?" .. query
        local ok, res = safeRequest({ Url = url, Method = "GET" })
        if not ok and Chat.Debug then
            warn("[Chat] AddUser failed: ", res and res.StatusCode)
        end
    end

    function Chat.Heartbeat(userId)
        local query = buildQuery({
            format = "json",
            event = "heartbeat",
            userid = userId,
        })
        local url = Chat.URL .. "?" .. query
        local ok, res = safeRequest({ Url = url, Method = "GET" })
        if not ok and Chat.Debug then
            warn("[Chat] Heartbeat failed: ", res and res.StatusCode)
        end
    end

    function Chat.SendMessage(userId, message, timestamp)
        timestamp = timestamp or math.floor(os.time())
        local query = buildQuery({
            format = "json",
            event = "chat",
            userid = userId,
            message = message,
            timestamp = timestamp,
        })
        local url = Chat.URL .. "?" .. query
        local ok, res = safeRequest({ Url = url, Method = "GET" }, 5) -- more retries for messages
        if not ok and Chat.Debug then
            warn("[Chat] SendMessage failed: ", res and res.StatusCode)
        end
        return ok
    end

    function Chat.GetMessages()
        local query = buildQuery({ format = "json" })
        local url = Chat.URL .. "?" .. query
        local ok, res = safeRequest({ Url = url, Method = "GET" })
        if ok and res and res.Body then
            local success, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
            if success then
                return data
            end
        end
        return { messages = {}, users = { value = 0, stored = {} } }
    end

