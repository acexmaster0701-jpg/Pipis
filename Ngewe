    local boxfarm_thread

    Start_BoxFarm = function()
        boxfarm_thread = task.spawn(LPH_NO_VIRTUALIZE(function()
            while task.wait() do
                if not Player.Character then continue end
                if not Player.Character:FindFirstChild("HumanoidRootPart") then continue end
                if not S.LILBRO.FarmingUtilities.BoxFarm then continue end

                if (Player.Character.HumanoidRootPart.Position - Vector3.new(-549, 3, -82)).Magnitude >= 150 then
