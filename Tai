            Page.Active = Bool

            if #Page.SubPages > 0 then
                for Index, Sub in ipairs(Page.SubPages) do
                    Sub:Turn(Bool and (Index == 1) or false)
                end
            end

            Debounce = true 

            if Bool then 
                Items["PageContent"].Instance.Visible = true
                Items["PageContent"].Instance.Parent = Page.Window.Items["Inline"].Instance
