-- ===== VEHICLE TP FUNCTION =====
S.TpVehicle = function(x, y, z)
    local ch = Player.Character
    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
    local seat = hum and hum.SeatPart
    if not seat then return end
    local vehicle = seat:FindFirstAncestorOfClass("Model")
    if not vehicle then return end
    for _, p in ipairs(vehicle:GetDescendants()) do
        if p:IsA("BasePart") then
            pcall(function()
                p.AssemblyLinearVelocity = Vector3.zero
                p.AssemblyAngularVelocity = Vector3.zero
                p.Anchored = true
            end)
        end
    end
    task.wait(0.05)
    local targetPos = Vector3.new(x, y, z)
    local anchor = vehicle.PrimaryPart or vehicle:FindFirstChildOfClass("VehicleSeat") or
        vehicle:FindFirstChildOfClass("BasePart")
    local newCF = CFrame.new(targetPos + Vector3.new(0, 0.5, 0), targetPos + Vector3.new(0, 0.5, 1))
    if vehicle.PrimaryPart then
        vehicle:SetPrimaryPartCFrame(newCF)
    elseif anchor then
        anchor.CFrame = newCF
    end
    task.wait(0.05)
    for _, p in ipairs(vehicle:GetDescendants()) do
        if p:IsA("BasePart") then
            pcall(function()
                p.Anchored = false
                p.AssemblyLinearVelocity = Vector3.zero
                p.AssemblyAngularVelocity = Vector3.zero
            end)
        end
    end
end

