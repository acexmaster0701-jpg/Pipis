                local DistanceFromTruck = GetDistance(Player.Character.HumanoidRootPart.Position,
                    Vector3.new(-401.04364013671875, 3.3621325492858887, -72.07713317871094))

                local Tween = Services.TweenService:Create(Player.Character.HumanoidRootPart,
                    TweenInfo.new(GetTweenSpeed(DistanceFromTruck), Enum.EasingStyle.Linear),
                    { CFrame = CFrame.new(-401.04364013671875, 3.3621325492858887, -72.07713317871094) })

