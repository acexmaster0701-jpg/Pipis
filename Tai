                    local TabBtn = Items["Inactive"].Instance
                    local Indicator = Page.Window.Items["TabIndicator"]
                    if Indicator then
                        Indicator.Instance.Visible = true
                        
                        local function updatePos()
                            local sidebarFrame = Page.Window.Items["Sidebar"].Instance
                            local indicatorHeight = TabBtn.AbsoluteSize.Y + 20
                            local yPos = TabBtn.AbsolutePosition.Y - sidebarFrame.AbsolutePosition.Y - 10
                            Indicator:Tween(TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                                Position = UDim2New(1, -3, 0, yPos),
                                Size = UDim2New(0, 3, 0, indicatorHeight)
                            })
                        end

                        if TabBtn.AbsolutePosition.Y == 0 then
                            task.spawn(function()
                                repeat task.wait() until TabBtn.AbsolutePosition.Y ~= 0
                                updatePos()
                            end)
                        else
                            updatePos()
                        end
                    end
                end
            else
                if Items["Inactive"] then
                    if isTextIcon then
                        Items["Inactive"]:Tween(nil, {TextTransparency = 0.5})
                    else
                        Items["Inactive"]:Tween(nil, {ImageTransparency = 0.5})
                    end
                end
            end

